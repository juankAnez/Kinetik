# Django
SECRET_KEY=generate-a-strong-secret-key-here
ALLOWED_HOSTS=kinetik.app,api.kinetik.app,admin.kinetik.app
DEBUG=False
LOG_LEVEL=info

# Database
DB_NAME=kinetik
DB_USER=kinetik
DB_PASSWORD=change-this-to-a-strong-password

# Redis
REDIS_HOST=redis

# CORS
CORS_ALLOWED_ORIGINS=https://kinetik.app,https://admin.kinetik.app

# Sentry (optional)
SENTRY_DSN=

# AWS S3 (optional - for media/static files)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# Gunicorn
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120
GUNICORN_MAX_REQUESTS=1000

# Celery
CELERY_WORKERS=4
CELERY_MAX_TASKS=1000
CELERY_TIME_LIMIT=300

# Rate limiting
RATE_LIMIT_API=30
RATE_LIMIT_AUTH=5

# Nginx
NGINX_SERVER_NAME=kinetik.app
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
CLIENT_MAX_BODY_SIZE=10M
